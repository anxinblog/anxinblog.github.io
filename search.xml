<th align="center">包装类</th>
<th align="center">父类</th>
</tr>
</thead>
<tbody><tr>
<td align="center">boolean</td>
<td align="center">Boolean</td>
<td align="center">Object</td>
</tr>
<tr>
<td align="center">char</td>
